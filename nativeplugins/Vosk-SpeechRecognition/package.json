{
  "name": "Vosk-SpeechRecognition",
  "id": "Vosk-SpeechRecognition",
  "version": "1.0.0",
  "description": "Vosk离线语音识别UniApp原生插件",
  "_dp_type": "nativeplugin",
  "_dp_nativeplugin": {
    "android": {
      "plugins": [
        {
          "type": "module",
          "name": "Vosk-SpeechRecognition",
          "class": "com.vosk.uniplugin.VoskModule"
        }
      ],
      "integrateType": "aar",
      "dependencies": [
        "net.java.dev.jna:jna:5.13.0@aar",
        "com.alphacephei:vosk-android:0.3.45@aar"
      ],
      "compileOptions": {
        "sourceCompatibility": "1.8",
        "targetCompatibility": "1.8"
      },
      "abis": ["armeabi-v7a", "arm64-v8a", "x86", "x86_64"],
      "minSdkVersion": 21,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "useAndroidX": true
    },
    "ios": {
      "plugins": [
        {
          "type": "module",
          "name": "Vosk-SpeechRecognition",
          "class": "VoskModule"
        }
      ],
      "integrateType": "framework",
      "deploymentTarget": "12.0"
    }
  }
}
